---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={post.data.title} description={post.data.description}>
  <section class="block">
    <div class="container prose">
      <p class="meta" style="color:var(--muted);">{post.data.date.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h1 style="margin-bottom:1rem;">{post.data.title}</h1>
      {post.data.image && <img src={post.data.image} alt={post.data.title} style="margin-bottom:1.5rem;" />}
      <Content />
    </div>
  </section>
</Base>
